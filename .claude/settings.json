{
  "permissions": {
    "allow": [
      "Bash(npm run start:*)",
      "Bash(npm run build:*)",
      "Bash(npm run serve:*)",
      "Bash(npm run clear:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm install:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(mv:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)"
    ]
  }
}
